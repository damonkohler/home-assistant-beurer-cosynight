# Ignore everything
*

# Allow repo structure
!.gitignore
!.markdownlint.json
!.pre-commit-config.yaml
!LICENSE
!README.md
!CHANGELOG.md
!hacs.json

# Allow integration source
!custom_components/
!custom_components/beurer_cosynight/
!custom_components/beurer_cosynight/*.py
!custom_components/beurer_cosynight/*.json
!custom_components/beurer_cosynight/*.yaml

# Allow test infrastructure
!tests/
!tests/*.py
!requirements-dev.txt
!pyproject.toml
